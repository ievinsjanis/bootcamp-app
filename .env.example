# Copy this file to .env and fill in values for local development.
# Never commit .env — it is already in .gitignore.

# Server port (Render sets PORT automatically; leave as-is for local dev)
PORT=3001

# Optional: GitHub personal access token.
# Used to resolve linked GitHub issue URLs in test-run reports.
# Needs: repo (read) scope.
# GITHUB_TOKEN=ghp_...
